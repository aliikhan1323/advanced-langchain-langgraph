# =============================================================================
# Environment variables — copy this file to `.env` and fill in real values.
# Never commit `.env` (it is in .gitignore).
# =============================================================================

# Groq LLM API (required)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL (optional — Part 5 persistence demo)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=langchain_db

# Hugging Face (optional — higher rate limits for embedding model downloads)
# HF_TOKEN=your_huggingface_token_here
